rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Premium CRM Security Rules - Management View
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the prototype, we allow authenticated users to act as managers.
      // In production, check for a document in /roles_admin/{userId} or a custom claim.
      return isSignedIn();
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    /**
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Admin SDK
    }

    /**
     * @path /leads/{leadId}
     * Root level collection for team-wide lead management.
     */
    match /leads/{leadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); 
    }

    /**
     * @path /activities/{activityId}
     * Root level collection for team-wide activity feed.
     */
    match /activities/{activityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @path /calendarEvents/{eventId}
     * Root level collection for team-wide calendar.
     */
    match /calendarEvents/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @path /teamSettings/{settingId}
     * Global team configurations like quotas.
     */
    match /teamSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}