/**
 * Firestore Security Rules - SalesStream Production
 * 
 * Flattened architecture for root-level collections with ownerUid enforcement.
 * This satisfies the 'Rules are not Filters' requirement and matches CRM query patterns.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isDocOwner() {
      return isOwner(resource.data.ownerUid);
    }

    function willBeOwner() {
      return isOwner(request.resource.data.ownerUid);
    }

    // --- User Profile ---
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    // --- Root Collections (Owner Scoped) ---
    
    // Applies to leads, contacts, notes, activities, calendarEvents, training_materials, tags
    match /{collectionName}/{docId} {
      allow get, list: if collectionName in [
        'leads', 'contacts', 'notes', 'activities', 
        'calendarEvents', 'training_materials', 'tags'
      ] && (
        (resource != null && isOwner(resource.data.ownerUid)) ||
        (resource == null && isSignedIn()) // Allow query checking
      );

      allow create: if collectionName in [
        'leads', 'contacts', 'notes', 'activities', 
        'calendarEvents', 'training_materials', 'tags'
      ] && willBeOwner();

      allow update, delete: if collectionName in [
        'leads', 'contacts', 'notes', 'activities', 
        'calendarEvents', 'training_materials', 'tags'
      ] && isDocOwner();
    }
  }
}