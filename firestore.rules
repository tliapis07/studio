rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Security Rules (Optimized for Root-Level Collections)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && (
        resource == null || 
        resource.data.ownerUid == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid
      );
    }

    function isWriteOwner() {
      return isSignedIn() && (
        request.resource.data.ownerUid == request.auth.uid || 
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.ownerId == request.auth.uid
      );
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Root-Level Data Collections (Leads, Contacts, Notes, etc.)
    match /leads/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /contacts/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /notes/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /calendarEvents/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /activities/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /training_materials/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }

    match /training_subjects/{docId} {
      allow read, delete: if isDocOwner();
      allow create: if isWriteOwner();
      allow update: if isDocOwner() && isWriteOwner();
    }
  }
}
