rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Security Rules
     * Optimized for per-collection ownership validation using ownerUid.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isCreatingAsOwner() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Global rule for all organizational data collections
    match /{collectionName}/{docId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isOwner() && isCreatingAsOwner();
    }
  }
}