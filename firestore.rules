rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Security Rules
     * Standardized on ownerUid for user-data isolation.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the existing document is owned by the requester
    function isOwner() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Checks if the new data being written assigns the requester as owner
    function isAssigningToSelf() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    // User Profile Rules: Path-based ownership
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Leads Collection
    match /leads/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }

    // Contacts Directory
    match /contacts/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }

    // Personal & Strategy Notes
    match /notes/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }

    // Activity Logs
    match /activities/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }

    // Team Calendar
    match /calendarEvents/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }

    // Training Repository
    match /training_materials/{id} {
      allow read, update, delete: if isOwner();
      allow create: if isAssigningToSelf();
    }
  }
}
