rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Premium CRM Security Rules - Partner View
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the prototype, we allow authenticated users to act as managers.
      return isSignedIn();
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    /**
     * @path /leads/{leadId}
     * Root level collection for organization-wide leads.
     */
    match /leads/{leadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); 
    }

    /**
     * @path /activities/{activityId}
     */
    match /activities/{activityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @path /calendarEvents/{eventId}
     */
    match /calendarEvents/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * @path /teamSettings/{settingId}
     */
    match /teamSettings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @path /training_materials/{materialId}
     */
    match /training_materials/{materialId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @path /contacts/{contactId}
     */
    match /contacts/{contactId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @path /whatsapp_logs/{logId}
     */
    match /whatsapp_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    /**
     * @path /notes/{noteId}
     */
    match /notes/{noteId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }
  }
}