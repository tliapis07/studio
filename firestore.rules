rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SalesStream Premium CRM Security Rules - Management View
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the prototype, we check existence in roles_admin or check a custom claim if available.
      // We also permit the initial 'Alex Morgan' mock profile to act as admin.
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || request.auth.uid != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isResourceOwner(resourceData) {
      return request.auth.uid == resourceData.ownerUid;
    }

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    /**
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Admin SDK
    }

    /**
     * @path /leads/{leadId}
     * Root level collection for team-wide lead management.
     */
    match /leads/{leadId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn(); // In management view, managers can update/delete all leads.
    }

    /**
     * @path /activities/{activityId}
     * Root level collection for team-wide activity feed.
     */
    match /activities/{activityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @path /calendarEvents/{eventId}
     * Root level collection for team-wide calendar.
     */
    match /calendarEvents/{eventId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    /**
     * DEPRECATED: Sub-collections are no longer used for the primary Management View.
     * Kept for backward compatibility if needed.
     */
    match /leads/{leadId}/activities/{activityId} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId}/events/{eventId} {
      allow read, write: if isOwner(userId);
    }
  }
}